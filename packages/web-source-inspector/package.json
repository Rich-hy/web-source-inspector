{
  "name": "web-source-inspector",
  "version": "0.1.0-beta.3",
  "description": "Open Vue template sources from Vite and Webpack development pages in VS Code or Cursor.",
  "keywords": [
    "vue",
    "vue2",
    "vue3",
    "vite",
    "webpack",
    "vue-cli",
    "devtools",
    "inspector",
    "source-map",
    "vscode",
    "cursor",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Rich-hy/web-source-inspector.git",
    "directory": "packages/web-source-inspector"
  },
  "bugs": {
    "url": "https://github.com/Rich-hy/web-source-inspector/issues"
  },
  "homepage": "https://github.com/Rich-hy/web-source-inspector#readme",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "web-source-inspector": "dist/cli.cjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./vite": {
      "import": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      },
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      }
    },
    "./webpack": {
      "import": {
        "types": "./dist/webpack.d.ts",
        "default": "./dist/webpack.js"
      },
      "require": {
        "types": "./dist/webpack.d.cts",
        "default": "./dist/webpack.cjs"
      }
    },
    "./browser-runtime": {
      "import": {
        "types": "./dist/browser-runtime.d.ts",
        "default": "./browser-runtime.js"
      }
    },
    "./webpack-loader": {
      "require": {
        "types": "./dist/webpack-loader.d.cts",
        "default": "./dist/webpack-loader.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "browser-runtime.js",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "engines": {
    "node": ">=16.20.2"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsup --config tsup.assets.config.ts",
    "prepack": "pnpm run build && pnpm run smoke:webpack-exports",
    "smoke:webpack-exports": "node scripts/smoke-webpack-exports.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/parser": "7.28.4",
    "magic-string": "0.30.21",
    "recast": "0.23.11",
    "semver": "7.7.2",
    "ws": "8.21.0"
  },
  "peerDependencies": {
    "@vitejs/plugin-vue": ">=2.0.0 <7.0.0",
    "@vitejs/plugin-vue2": ">=2.0.0 <3.0.0",
    "@vue/compiler-dom": ">=3.2.0",
    "@vue/compiler-sfc": ">=3.2.0",
    "vite": ">=2.9.0 <7.0.0",
    "vite-plugin-vue2": ">=2.0.0 <3.0.0",
    "vue": ">=2.6.0 <2.8.0 || >=3.2.0 <4.0.0",
    "vue-loader": ">=15.0.0 <18.0.0",
    "vue-template-compiler": "^2.6.0",
    "webpack": ">=4.0.0 <6.0.0",
    "webpack-dev-server": "^3.0.0 || >=4.7.0 <5.0.0"
  },
  "peerDependenciesMeta": {
    "@vitejs/plugin-vue": { "optional": true },
    "@vitejs/plugin-vue2": { "optional": true },
    "@vue/compiler-dom": { "optional": true },
    "@vue/compiler-sfc": { "optional": true },
    "vite": { "optional": true },
    "vite-plugin-vue2": { "optional": true },
    "vue": { "optional": true },
    "vue-loader": { "optional": true },
    "vue-template-compiler": { "optional": true },
    "webpack": { "optional": true },
    "webpack-dev-server": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "24.3.1",
    "@web-source-inspector/adapter-webpack": "workspace:*",
    "@web-source-inspector/init-core": "workspace:*",
    "@web-source-inspector/protocol": "workspace:*",
    "@web-source-inspector/runtime": "workspace:*",
    "@web-source-inspector/vite-plugin": "workspace:*",
    "tsup": "8.5.0"
  }
}
