{
  "name": "@web-source-inspector/protocol",
  "version": "0.1.0",
  "private": true,
  "description": "Shared wire types, limits, events, and runtime validators for Web Source Inspector.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "catalog:"
  }
}
